#################################### set box ###########################################################
units           real
atom_style      full
boundary        p p p

########################### set initial config and FF ###################################################
pair_style      lj/cut 12.5
bond_style      harmonic
angle_style     hybrid fourier cosine/periodic
dihedral_style  harmonic
improper_style  fourier

pair_modify     tail yes mix arithmetic
dielectric      1.0
special_bonds   lj/coul 0.0 0.0 1.0
box tilt        large
read_data       Config_1.data # change the configuration files for each short tranjectory

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

group           frame type 1:5
group           adsorbate type 6
 
############################ monitoring simulation #################################################
variable        t equal 308.15
variable        s equal 1123 #random seed

thermo          1000 
thermo_style	custom step etotal pe ke vol press temp
compute         t_temp all temp
thermo_modify	temp t_temp format float %4.10g

################################# pre-run setting #####################################################
reset_timestep	0
timestep        1
run_style       verlet
fix             TETHER1 all momentum 1 linear 1 1 1 angular
velocity        all create $t $s rot yes mom yes dist gaussian

include         REGIONS.data # prevent the adsorbate from escaping the cage
region          TOTALREGION union 2 sphere_1 sphere_2
fix             REGION adsorbate wall/region TOTALREGION harmonic 200 0 1
fix_modify      REGION energy yes

dump            framework frame xyz 600000 framework.xyz
dump_modify     framework element O Mn Cl C H Na

#####################################  NVT #############################################################
fix             NVT_ENSEMBLE all nvt temp $t $t 100 

dump            initial_velocity adsorbate custom 10000 dump.initial_velocity id type vx vy vz
dump            trajectory_movie adsorbate xyz 100 MOVIE_slab.xyz
dump_modify     trajectory_movie element O Mn Cl C H Na 

fix             REALRUN all colvars run.colvars 
run             5000
unfix           REALRUN
